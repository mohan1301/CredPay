# =====================================================================
# CredPay - Example variable values
# Copy to terraform.tfvars and adjust. Do NOT commit real tfvars.
# =====================================================================

# Azure Subscription ID
subscription_id = "00000000-0000-0000-0000-000000000000"

# Azure Region
location = "eastus"

# ----- Networking -----
vnet_address_space     = "10.0.0.0/16"
aks_subnet_prefix      = "10.0.0.0/20"
postgres_subnet_prefix = "10.0.16.0/24"

# ----- AKS -----
node_count     = 3
node_min_count = 2
node_max_count = 5
vm_size        = "Standard_DS2_v2"

# ----- PostgreSQL -----
postgres_version        = "16"
postgres_admin_username = "credpayadmin"
database_name           = "credpay"

# ----- Monitoring -----
log_retention_days = 30
